# --- LLM (Azure OpenAI — used by agent/main.py) ---

AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
OPENAI_API_VERSION=2024-08-01-preview

# Legacy aliases (optional; Next.js direct-Azure fallback in route.ts)
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=2024-08-01-preview
AZURE_DEPLOYMENT_NAME=gpt-4o

# OpenAI (only if not using Azure)
OPENAI_API_KEY=

# --- Financial Planning / Airtable API (separate from LangGraph agent on :8000) ---
# Run: python backend/airtable_main.py  (listens on FASTAPI_PORT, default 8001)
FASTAPI_BASE_URL=http://localhost:8001
FASTAPI_PORT=8001

# --- Airtable ---
AIRTABLE_BASE_ID=
AIRTABLE_TABLE=Table 1
AIRTABLE_TOKEN=

# --- Web search (optional but used by the demo) ---
TAVILY_API_KEY=

# --- LangGraph agent (recommended: routes LLM through agent instead of direct Azure) ---
# Start the agent first: cd agent && pip install -r requirements.txt && python main.py
LANGGRAPH_AGENT_URL=http://localhost:8000/copilotkit
# LANGGRAPH_AGENT_PORT=8000
# NEXT_PUBLIC_LANGGRAPH_AGENT_ID=dashboard_agent
