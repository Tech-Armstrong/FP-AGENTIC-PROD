# OCR microservice — copy to ocr-service/.env (never commit .env)
#
# Keys are namespaced so they do NOT collide with the gpt-4o agent, which reads
# AZURE_OPENAI_* / AZURE_API_*. The OCR service must never use those generic names.

OCR_SERVICE_PORT=8010
OCR_MAX_UPLOAD_BYTES=10485760
# Pages of each PDF sent to Azure DI (key policy facts are in the first pages).
OCR_PAGE_RANGE=1-6

# Azure Document Intelligence (OCR / layout)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# Claude Sonnet 4.5 extraction via DSPy (Azure AI deployment).
# Do NOT set an api_version here — Claude via LiteLLM breaks if it is passed.
AZURE_EXTRACTION_ENDPOINT=
AZURE_EXTRACTION_KEY=
AZURE_EXTRACTION_DEPLOYMENT=claude-sonnet-4-5
